APP_NAME=Onleaked
APP_ENV=production
# IMPORTANT : générer avec `php artisan key:generate` avant le premier démarrage !
APP_KEY=
APP_DEBUG=false
APP_URL=https://onleaked.nealix.org
APP_LOCALE=fr

# ── PostgreSQL ──
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=onleaked_db
DB_USERNAME=onleaked_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis (Queue + Cache + Session) ──
# IMPORTANT : définir un mot de passe Redis en production (redis.conf : requirepass)
QUEUE_CONNECTION=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── SMTP (Brevo gratuit : 300 mails/jour) ──
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your_brevo_login@email.com
MAIL_PASSWORD=your_brevo_smtp_key
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@onleaked.nealix.org
MAIL_FROM_NAME="Onleaked"

# ── APIs OSINT ──
# EmailRep.io — gratuit limité, clé recommandée : https://emailrep.io/key
EMAILREP_API_KEY=

# BreachDirectory — via RapidAPI, plan gratuit disponible
BREACHDIRECTORY_API_KEY=

# HaveIBeenPwned — clé API requise pour la recherche par email : https://haveibeenpwned.com/API/Key
# Sans clé, le service HIBP retourne une réponse dégradée (no email search)
HIBP_API_KEY=

# ── Cache (résultats valables 24h par défaut) ──
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ── Logs ──
LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
